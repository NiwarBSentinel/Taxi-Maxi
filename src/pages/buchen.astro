---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  ArrowLeft,
  ArrowRight,
  MapPin,
  Clock,
  Car,
  Info,
} from "@lucide/astro";

const title = "Fahrt buchen · Taxi-Maxi";
const description = "Schritt 2 von 2: Bestellung prüfen und absenden.";
---

<BaseLayout
  title={title}
  description={description}
  ogTitle={title}
  ogDescription={description}
  canonicalPath="/buchen"
  solidHeader={true}
  robots="noindex, nofollow"
  bodyClass="bg-slate-50 text-dark antialiased"
>
  <div class="pt-32 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-slate-600 hover:text-primary mb-6 text-sm font-medium transition-colors"
      >
        <ArrowLeft size={16} strokeWidth={2} />
        Zurück zur Startseite
      </a>

      <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-2">
        Fahrt buchen
      </h1>
      <p class="text-slate-600 mb-8">
        Schritt 2 von 2 · Prüfen Sie Ihre Bestellung und senden Sie ab.
      </p>

      <!-- Bestellungs-Card -->
      <div
        class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-6"
      >
        <div class="p-6 md:p-7">
          <h2 class="text-lg font-bold text-slate-900 mb-5">Deine Bestellung</h2>

          <div class="flex items-start gap-4 py-3 border-b border-slate-100">
            <div
              class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center flex-shrink-0"
            >
              <MapPin size={18} strokeWidth={2} class="text-orange-500" />
            </div>
            <div class="flex-1 min-w-0">
              <p
                class="text-xs uppercase tracking-wide text-slate-500 font-semibold mb-0.5"
              >
                Von
              </p>
              <p
                id="summary-from"
                class="text-base font-medium text-slate-900 break-words"
              >
                —
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4 py-3 border-b border-slate-100">
            <div
              class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center flex-shrink-0"
            >
              <MapPin size={18} strokeWidth={2} class="text-orange-500" />
            </div>
            <div class="flex-1 min-w-0">
              <p
                class="text-xs uppercase tracking-wide text-slate-500 font-semibold mb-0.5"
              >
                Nach
              </p>
              <p
                id="summary-to"
                class="text-base font-medium text-slate-900 break-words"
              >
                —
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4 py-3">
            <div
              class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center flex-shrink-0"
            >
              <Clock size={18} strokeWidth={2} class="text-orange-500" />
            </div>
            <div class="flex-1">
              <p
                class="text-xs uppercase tracking-wide text-slate-500 font-semibold mb-0.5"
              >
                Wann
              </p>
              <p id="summary-when" class="text-base font-medium text-slate-900">
                —
              </p>
            </div>
          </div>

          <a
            href="/"
            class="text-sm text-primary hover:underline mt-4 inline-block"
          >
            ← Bestellung ändern
          </a>
        </div>
      </div>

      <!-- Taxi + Preis-Card -->
      <div
        class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden mb-6"
      >
        <div class="p-6 md:p-7">
          <h2 class="text-lg font-bold text-slate-900 mb-5">Dein Taxi</h2>

          <div
            id="taxi-card"
            class="border-2 border-primary rounded-xl p-5 flex items-center gap-5 transition-all"
          >
            <div
              class="w-14 h-14 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0"
            >
              <Car size={28} strokeWidth={2} class="text-primary" />
            </div>

            <div class="flex-1 min-w-0">
              <h3 class="text-base font-bold text-slate-900">Standard</h3>
              <p id="travel-time" class="text-sm text-slate-500 mt-0.5">
                Wird berechnet…
              </p>
            </div>

            <div class="text-right">
              <p
                id="price-display"
                class="text-xl font-extrabold text-slate-900"
              >
                <span class="inline-block animate-pulse text-slate-300"
                  >CHF –.–</span
                >
              </p>
              <p id="distance-display" class="text-xs text-slate-500 mt-0.5"></p>
            </div>
          </div>

          <p
            id="price-disclaimer"
            class="text-xs text-slate-500 mt-4 leading-relaxed inline-flex items-start gap-1.5"
          >
            <Info
              size={14}
              strokeWidth={2}
              class="flex-shrink-0 mt-0.5 text-slate-400"
            />
            <span
              >Richtpreis basierend auf Luftlinie × 1.3 (Strassenfaktor) ·
              Grundtaxe CHF 6.– + CHF 5.– pro km. Endpreis kann je nach Verkehr
              und Route abweichen.</span
            >
          </p>
        </div>
      </div>

      <!-- Sticky Footer: Total + Confirm -->
      <div
        class="bg-white rounded-2xl border border-slate-200 shadow-md p-5 flex items-center justify-between gap-4 sticky bottom-4 lg:static z-20"
      >
        <div>
          <p
            class="text-xs text-slate-500 font-semibold uppercase tracking-wide"
          >
            Richtpreis
          </p>
          <p
            id="total-price"
            class="text-2xl font-extrabold text-slate-900 leading-none mt-1"
          >
            <span class="inline-block animate-pulse text-slate-300">CHF –.–</span>
          </p>
        </div>

        <button
          id="confirm-btn"
          type="button"
          class="bg-primary hover:bg-primary-light text-white font-bold px-6 py-4 rounded-xl flex items-center gap-2 transition-all hover:scale-[1.02] hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 disabled:hover:shadow-none"
          disabled
        >
          <span class="hidden sm:inline">Per WhatsApp bestätigen</span>
          <span class="sm:hidden">Bestätigen</span>
          <ArrowRight size={20} strokeWidth={2.5} />
        </button>
      </div>

      <div class="text-center mt-8">
        <p class="text-sm text-slate-600">
          Lieber direkt anrufen?
          <a
            href="tel:+41441234567"
            class="text-primary font-semibold hover:underline ml-1"
          >
            044 123 45 67
          </a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const from = (params.get("from") || "").trim();
    const to = (params.get("to") || "").trim();
    const when = (params.get("when") || "Sofort").trim();

    if (!from || !to) {
      window.location.href = "/";
      return;
    }

    const summaryFrom = document.getElementById("summary-from");
    const summaryTo = document.getElementById("summary-to");
    const summaryWhen = document.getElementById("summary-when");
    const priceDisplay = document.getElementById("price-display");
    const totalPrice = document.getElementById("total-price");
    const distanceDisplay = document.getElementById("distance-display");
    const travelTime = document.getElementById("travel-time");
    const disclaimer = document.getElementById("price-disclaimer");
    const confirmBtn = document.getElementById("confirm-btn");

    if (summaryFrom) summaryFrom.textContent = from;
    if (summaryTo) summaryTo.textContent = to;
    if (summaryWhen) summaryWhen.textContent = when;

    function formatChf(value) {
      return "CHF " + value.toFixed(2).replace(".00", ".–");
    }

    function calculatePrice(km) {
      const BASE = 6;
      const PER_KM = 5;
      const raw = BASE + km * PER_KM;
      return Math.ceil(raw * 2) / 2;
    }

    function estimateMinutes(km) {
      const AVG_KMH = 40;
      return Math.max(5, Math.round((km / AVG_KMH) * 60));
    }

    function haversineKm(lat1, lon1, lat2, lon2) {
      const R = 6371;
      const dLat = ((lat2 - lat1) * Math.PI) / 180;
      const dLon = ((lon2 - lon1) * Math.PI) / 180;
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos((lat1 * Math.PI) / 180) *
          Math.cos((lat2 * Math.PI) / 180) *
          Math.sin(dLon / 2) ** 2;
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    }

    async function geocode(address) {
      const lower = address.toLowerCase();
      const query =
        lower.indexOf("schweiz") !== -1 || lower.indexOf("zürich") !== -1
          ? address
          : address + ", Zürich, Schweiz";

      const url =
        "https://nominatim.openstreetmap.org/search?q=" +
        encodeURIComponent(query) +
        "&format=json&limit=1&countrycodes=ch";

      const response = await fetch(url, {
        headers: { "Accept-Language": "de-CH" },
      });
      if (!response.ok) throw new Error("Geocoding HTTP " + response.status);

      const data = await response.json();
      if (!data || data.length === 0) {
        throw new Error("Adresse nicht gefunden: " + address);
      }
      return {
        lat: parseFloat(data[0].lat),
        lon: parseFloat(data[0].lon),
        display: data[0].display_name,
      };
    }

    function buildWhatsAppUrl(extra) {
      const phone = "41441234567";
      let message =
        "Hallo Taxi-Maxi 👋\n\n" +
        "Ich möchte eine Fahrt buchen:\n\n" +
        "📍 Von: " +
        from +
        "\n" +
        "📍 Nach: " +
        to +
        "\n" +
        "🕐 Wann: " +
        when +
        "\n";
      if (extra) message += extra;
      message += "\nVielen Dank!";
      return (
        "https://wa.me/" + phone + "?text=" + encodeURIComponent(message)
      );
    }

    function enableConfirm(extra) {
      if (!confirmBtn) return;
      confirmBtn.disabled = false;
      confirmBtn.addEventListener("click", function () {
        window.open(buildWhatsAppUrl(extra), "_blank");
      });
    }

    async function calculateAndDisplay() {
      try {
        const a = await geocode(from);
        await new Promise(function (r) {
          setTimeout(r, 1100);
        });
        const b = await geocode(to);

        const straightKm = haversineKm(a.lat, a.lon, b.lat, b.lon);
        const routeKm = straightKm * 1.3;
        const price = calculatePrice(routeKm);
        const minutes = estimateMinutes(routeKm);

        if (priceDisplay) priceDisplay.textContent = formatChf(price);
        if (totalPrice) totalPrice.textContent = formatChf(price);
        if (distanceDisplay)
          distanceDisplay.textContent = routeKm.toFixed(1) + " km";
        if (travelTime)
          travelTime.textContent = "Geschätzt ca. " + minutes + " Min";

        const extra =
          "\n📏 Distanz: " +
          routeKm.toFixed(1) +
          " km\n" +
          "⏱ Fahrzeit: ca. " +
          minutes +
          " Min\n" +
          "💰 Richtpreis: " +
          formatChf(price) +
          "\n";
        enableConfirm(extra);
      } catch (err) {
        console.error("Price calculation failed:", err);

        if (priceDisplay)
          priceDisplay.innerHTML =
            '<span class="text-base font-bold text-slate-700">Auf Anfrage</span>';
        if (totalPrice)
          totalPrice.innerHTML =
            '<span class="text-base font-bold text-slate-700">Auf Anfrage</span>';
        if (distanceDisplay) distanceDisplay.textContent = "";
        if (travelTime)
          travelTime.textContent =
            "Adresse konnte nicht automatisch geprüft werden";
        if (disclaimer)
          disclaimer.innerHTML =
            "Wir berechnen den Preis individuell. Senden Sie die Bestellung ab — wir bestätigen umgehend mit einem konkreten Angebot.";

        enableConfirm("\nBitte um Preisangabe.\n");
      }
    }

    calculateAndDisplay();
  })();
</script>

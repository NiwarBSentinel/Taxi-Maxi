---
import { Heart } from "@lucide/astro";

const cols = [
  {
    title: "Services",
    items: [
      { href: "/#services", label: "Standard-Taxi" },
      { href: "/#services", label: "Flughafen-Transfer" },
      { href: "/#services", label: "Geschäftskunden" },
    ],
  },
  {
    title: "Unternehmen",
    items: [
      { href: "/#versprechen", label: "Über uns" },
      { href: "/#kontakt", label: "Karriere" },
      { href: "/#kontakt", label: "Kontakt" },
    ],
  },
  {
    title: "Rechtliches",
    items: [
      { href: "/impressum", label: "Impressum" },
      { href: "/datenschutz", label: "Datenschutz" },
      { href: "/agb", label: "AGB" },
    ],
  },
];
---

<footer class="relative bg-white border-t border-slate-200">
  <div class="race-stripe-container" aria-hidden="true">
    <div class="race-stripe"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a
          href="/"
          class="inline-flex items-center"
          aria-label="Taxi Shiar - Startseite"
        >
          <img
            src="/images/Taxi-shiar-logo.png"
            alt="Taxi Shiar Logo"
            class="h-20 md:h-24 w-auto object-contain"
            loading="lazy"
            width="711"
            height="400"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-slate-600">
          Ihr Taxi im Limmattal & Region Zürich. 24/7.
        </p>
      </div>
      {
        cols.map((col) => (
          <div>
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">
              {col.title}
            </h3>
            <ul class="space-y-3 text-sm">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-slate-700 hover:text-primary transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="mt-14 pt-6 border-t border-slate-200">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm text-slate-500 text-center sm:text-left">
          © 2026 Taxi Shiar GmbH · Konzessioniert in Zürich
        </p>
        <a
          href="https://www.smartbranding.ch/"
          target="_blank"
          rel="noopener noreferrer"
          class="powered-by-link inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-900 transition-colors group"
        >
          <span>Made with</span>
          <Heart
            size={14}
            fill="currentColor"
            class="text-red-500 group-hover:scale-110 transition-transform"
          />
          <span>by</span>
          <img
            src="/images/smartbranding-logo-blue.svg"
            alt="Smart Branding"
            class="h-5 w-auto object-contain"
            loading="lazy"
          />
        </a>
      </div>
    </div>
  </div>
</footer>

<style is:global>
  .race-stripe-container {
    position: relative;
    height: 16px;
    background-color: #FFC72C;
    overflow: hidden;
  }
  .race-stripe {
    position: absolute;
    inset: 0;
    width: calc(100% + 32px);
    background-image:
      linear-gradient(
        45deg,
        #0F172A 25%,
        transparent 25%,
        transparent 75%,
        #0F172A 75%
      ),
      linear-gradient(
        45deg,
        #0F172A 25%,
        transparent 25%,
        transparent 75%,
        #0F172A 75%
      );
    background-size: 16px 16px;
    background-position: 0 0, 8px 8px;
    animation: race-stripe-slide 2s linear infinite;
  }
  @keyframes race-stripe-slide {
    0% {
      background-position: 0 0, 8px 8px;
    }
    100% {
      background-position: 16px 0, 24px 8px;
    }
  }
  .race-stripe-container::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.15), transparent);
    pointer-events: none;
    z-index: 2;
  }
  .race-stripe-container::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.1), transparent);
    pointer-events: none;
    z-index: 2;
  }
  @media (prefers-reduced-motion: reduce) {
    .race-stripe {
      animation: none;
    }
  }

  .powered-by-link img {
    filter: grayscale(20%);
    transition: filter 250ms ease;
  }
  .powered-by-link:hover img {
    filter: grayscale(0%);
  }
  @media (prefers-reduced-motion: reduce) {
    .powered-by-link img,
    .powered-by-link svg {
      transition: none !important;
    }
  }
</style>

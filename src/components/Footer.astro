---
import { Heart } from "@lucide/astro";

const cols = [
  {
    title: "Services",
    items: [
      { href: "/#services", label: "Standard-Taxi" },
      { href: "/#services", label: "Flughafen-Transfer" },
      { href: "/#services", label: "Geschäftskunden" },
    ],
  },
  {
    title: "Unternehmen",
    items: [
      { href: "/#versprechen", label: "Über uns" },
      { href: "/#kontakt", label: "Karriere" },
      { href: "/#kontakt", label: "Kontakt" },
    ],
  },
  {
    title: "Rechtliches",
    items: [
      { href: "/impressum", label: "Impressum" },
      { href: "/datenschutz", label: "Datenschutz" },
      { href: "/agb", label: "AGB" },
    ],
  },
];
---

<footer class="relative bg-white border-t border-slate-200">
  <div class="race-stripe-container" aria-hidden="true">
    <div class="race-stripe"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a
          href="/"
          class="inline-flex items-center"
          aria-label="Taxi Shiar - Startseite"
        >
          <img
            src="/images/Taxi-shiar-logo.png"
            alt="Taxi Shiar Logo"
            class="h-14 w-auto object-contain"
            loading="lazy"
            width="1920"
            height="1080"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-slate-600">
          Ihr Taxi im Limmattal & Region Zürich. 24/7.
        </p>
      </div>
      {
        cols.map((col) => (
          <div>
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">
              {col.title}
            </h3>
            <ul class="space-y-3 text-sm">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-slate-700 hover:text-primary transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div
      class="mt-14 pt-8 border-t border-slate-200 text-xs text-slate-500 text-center flex items-center justify-center flex-wrap gap-1"
    >
      <span>© 2026 Taxi Shiar GmbH · Konzessioniert in Zürich · Made with</span>
      <Heart size={14} fill="currentColor" class="inline text-accent" />
      <span>in Zürich</span>
    </div>
  </div>
</footer>

<style is:global>
  .race-stripe-container {
    position: relative;
    height: 16px;
    background-color: #FFC72C;
    overflow: hidden;
  }
  .race-stripe {
    position: absolute;
    inset: 0;
    width: calc(100% + 32px);
    background-image:
      linear-gradient(
        45deg,
        #0F172A 25%,
        transparent 25%,
        transparent 75%,
        #0F172A 75%
      ),
      linear-gradient(
        45deg,
        #0F172A 25%,
        transparent 25%,
        transparent 75%,
        #0F172A 75%
      );
    background-size: 16px 16px;
    background-position: 0 0, 8px 8px;
    animation: race-stripe-slide 4s linear infinite;
  }
  @keyframes race-stripe-slide {
    0% {
      background-position: 0 0, 8px 8px;
    }
    100% {
      background-position: 16px 0, 24px 8px;
    }
  }
  .race-stripe-container::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.15), transparent);
    pointer-events: none;
    z-index: 2;
  }
  .race-stripe-container::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.1), transparent);
    pointer-events: none;
    z-index: 2;
  }
  @media (prefers-reduced-motion: reduce) {
    .race-stripe {
      animation: none;
    }
  }
</style>

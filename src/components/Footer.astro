---
import { Heart } from "@lucide/astro";

const cols = [
  {
    title: "Services",
    items: [
      { href: "/#services", label: "Standard-Taxi" },
      { href: "/#services", label: "Flughafen-Transfer" },
      { href: "/#services", label: "Geschäftskunden" },
    ],
  },
  {
    title: "Unternehmen",
    items: [
      { href: "/#versprechen", label: "Über uns" },
      { href: "/#kontakt", label: "Karriere" },
      { href: "/#kontakt", label: "Kontakt" },
    ],
  },
  {
    title: "Rechtliches",
    items: [
      { href: "/impressum", label: "Impressum" },
      { href: "/datenschutz", label: "Datenschutz" },
      { href: "/agb", label: "AGB" },
    ],
  },
];
---

<footer class="relative bg-white border-t border-slate-200">
  <div class="relative h-1 bg-slate-100 overflow-hidden">
    <div
      class="absolute inset-y-0 left-0 w-1/3 bg-gradient-to-r from-transparent via-accent to-transparent animate-gold-stripe"
    >
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a
          href="/"
          class="inline-flex items-center"
          aria-label="Taxi Shiar - Startseite"
        >
          <img
            src="/images/Taxi-shiar-logo.png"
            alt="Taxi Shiar Logo"
            class="h-14 w-auto object-contain"
            loading="lazy"
            width="1920"
            height="1080"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-slate-600">
          Ihr Taxi im Limmattal & Region Zürich. 24/7.
        </p>
      </div>
      {
        cols.map((col) => (
          <div>
            <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-5">
              {col.title}
            </h3>
            <ul class="space-y-3 text-sm">
              {col.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-slate-700 hover:text-primary transition-colors"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div
      class="mt-14 pt-8 border-t border-slate-200 text-xs text-slate-500 text-center flex items-center justify-center flex-wrap gap-1"
    >
      <span>© 2026 Taxi Shiar GmbH · Konzessioniert in Zürich · Made with</span>
      <Heart size={14} fill="currentColor" class="inline text-accent" />
      <span>in Zürich</span>
    </div>
  </div>
</footer>

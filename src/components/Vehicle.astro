---
import { Users, Snowflake, Volume2, Sparkles, Zap } from "@lucide/astro";

const specs = [
  { Icon: Users, label: "5 Sitzplätze" },
  { Icon: Snowflake, label: "Klimatisiert" },
  { Icon: Volume2, label: "Flüsterleise" },
  { Icon: Zap, label: "E-Hybrid" },
  { Icon: Sparkles, label: "Frisch gereinigt" },
];
---

<section
  id="fahrzeug"
  class="relative overflow-hidden bg-gradient-to-b from-dark via-primary-dark to-dark py-24 md:py-32"
>
  <!-- Hintergrund-Tiefe -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-noise opacity-[0.05] mix-blend-overlay"></div>
    <div
      class="absolute inset-0"
      style="background: radial-gradient(55% 45% at 50% 30%, rgba(59,130,246,0.25), transparent 70%);"
    >
    </div>
    <div
      class="absolute inset-0"
      style="background: radial-gradient(40% 35% at 85% 90%, rgba(255,199,44,0.12), transparent 70%);"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-2xl mx-auto text-center reveal-up">
      <p
        class="inline-flex items-center gap-2 text-accent text-sm font-semibold uppercase tracking-widest mb-4"
      >
        <span class="w-2 h-2 rounded-full bg-accent"></span>
        Unser Fahrzeug
      </p>
      <h2
        class="text-white text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-5"
      >
        Reisen Sie in <span class="text-accent">Stil und Komfort.</span>
      </h2>
      <p class="text-white/70 text-lg leading-relaxed">
        Sie fahren im vollausgestatteten BYD Seal U DM-i — modern, sicher und
        nach jeder Schicht frisch gereinigt.
      </p>
    </div>

    <!-- Showroom-Bühne: Front-Fahrzeug mit Spotlight + Spiegelung -->
    <div class="relative mt-8 md:mt-4 mb-14 md:mb-20 reveal-scale">
      <!-- Spotlight-Glow -->
      <div
        class="absolute inset-0 flex items-center justify-center pointer-events-none"
      >
        <div
          class="w-[70%] h-[75%] rounded-full bg-gradient-to-br from-blue-400/25 via-accent/10 to-transparent blur-3xl"
        >
        </div>
      </div>
      <!-- Boden-Lichtellipse -->
      <div
        class="absolute bottom-[14%] left-1/2 -translate-x-1/2 w-[55%] h-10 bg-white/10 rounded-[50%] blur-2xl pointer-events-none"
      >
      </div>

      <div class="relative mx-auto max-w-3xl">
        <img
          src="/images/fahrzeug-front-cut.webp"
          alt="BYD Seal U DM-i der Taxi Shiar Flotte"
          loading="lazy"
          decoding="async"
          width="1300"
          height="600"
          class="relative z-10 w-full h-auto object-contain drop-shadow-2xl"
        />
        <!-- Spiegelung -->
        <img
          src="/images/fahrzeug-front-cut.webp"
          alt=""
          aria-hidden="true"
          loading="lazy"
          decoding="async"
          class="vehicle-reflection absolute inset-x-0 top-full w-full h-auto object-contain -mt-4 scale-y-[-1] opacity-25 pointer-events-none select-none"
        />
      </div>
    </div>

    <!-- Spec-Pills -->
    <ul
      class="flex flex-wrap justify-center gap-2.5 sm:gap-3 mb-16 md:mb-20 reveal-up"
    >
      {
        specs.map(({ Icon, label }) => (
          <li class="inline-flex items-center gap-2 rounded-full bg-white/[0.07] border border-white/10 px-4 py-2.5 text-sm font-medium text-white backdrop-blur-sm">
            <Icon size={15} strokeWidth={2.25} class="text-accent" />
            {label}
          </li>
        ))
      }
    </ul>

    <!-- Interieur + Seitenprofil -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-8 items-stretch">
      <!-- Interieur-Foto -->
      <figure
        class="lg:col-span-3 relative rounded-3xl overflow-hidden ring-1 ring-white/10 shadow-2xl reveal-up group"
      >
        <img
          src="/images/fahrzeug-interieur.webp"
          alt="Premium-Interieur des BYD Seal U DM-i — Cockpit mit grossem Touchscreen"
          loading="lazy"
          decoding="async"
          width="1800"
          height="772"
          class="vehicle-interior w-full h-full object-cover aspect-[16/10] lg:aspect-auto lg:min-h-[320px]"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-dark/80 via-transparent to-transparent pointer-events-none"
        >
        </div>
        <figcaption
          class="absolute bottom-0 left-0 p-6 sm:p-7"
        >
          <p
            class="text-accent text-xs font-semibold uppercase tracking-widest mb-1"
          >
            Premium-Interieur
          </p>
          <p class="text-white text-lg font-bold leading-tight">
            Platz nehmen, zurücklehnen, ankommen.
          </p>
        </figcaption>
      </figure>

      <!-- Seitenprofil als kleine Bühne -->
      <figure
        class="lg:col-span-2 relative flex flex-col justify-center rounded-3xl overflow-hidden bg-white/[0.04] ring-1 ring-white/10 p-6 sm:p-8 reveal-up"
        style="--reveal-delay: 120ms"
      >
        <div
          class="absolute bottom-[26%] left-1/2 -translate-x-1/2 w-[70%] h-8 bg-white/10 rounded-[50%] blur-2xl pointer-events-none"
        >
        </div>
        <img
          src="/images/fahrzeug-seite-cut.webp"
          alt="BYD Seal U DM-i — Seitenprofil"
          loading="lazy"
          decoding="async"
          width="1300"
          height="480"
          class="relative z-10 w-full h-auto object-contain drop-shadow-xl"
        />
        <figcaption class="relative mt-4 text-center">
          <p
            class="text-accent text-xs font-semibold uppercase tracking-widest mb-1"
          >
            Seitenprofil
          </p>
          <p class="text-white/70 text-sm">
            Grosszügig, geräumig, mit viel Platz für Gepäck.
          </p>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<style>
  .vehicle-reflection {
    -webkit-mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.5),
      transparent 55%
    );
    mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.5),
      transparent 55%
    );
  }
  .vehicle-interior {
    transition: transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (prefers-reduced-motion: no-preference) {
    .group:hover .vehicle-interior {
      transform: scale(1.05);
    }
  }
</style>

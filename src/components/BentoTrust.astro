---
import { Clock, Phone, ShieldCheck, TrendingDown } from "@lucide/astro";
---

<section
  id="trust"
  class="relative py-24 md:py-32 bg-gradient-to-b from-slate-50 to-white overflow-hidden"
>
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.4]"
    style="background-image: radial-gradient(circle, rgb(203 213 225) 1px, transparent 1px); background-size: 24px 24px;"
  >
  </div>

  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <defs>
      <linearGradient id="partial-fill" x1="0" x2="1" y1="0" y2="0">
        <stop offset="0.9" stop-color="rgb(245 158 11)"></stop>
        <stop offset="0.9" stop-color="rgb(203 213 225)"></stop>
      </linearGradient>
    </defs>
  </svg>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal-up max-w-3xl mb-14">
      <p class="text-primary text-sm font-semibold uppercase tracking-widest mb-3">
        Echte Daten · Echte Fahrten
      </p>
      <h2
        class="text-slate-900 text-4xl md:text-5xl font-extrabold leading-tight mb-4"
      >
        Zürich vertraut uns.
      </h2>
      <p class="text-slate-600 text-lg max-w-2xl">
        Sechs Beweise aus dem Alltag. Aktualisiert mit Daten von echten Fahrten in
        Zürich und Umgebung.
      </p>
    </div>

    <div
      id="bento-grid"
      class="grid grid-cols-12 grid-flow-dense gap-4 md:gap-5 auto-rows-[180px] md:auto-rows-[220px]"
    >
      <!-- TILE 1: Wartezeit -->
      <article
        data-tile="0"
        class="bento-tile group col-span-12 md:col-span-5 row-span-1 relative bg-white border border-slate-200 rounded-2xl p-6 md:p-7 flex flex-col justify-between shadow-sm overflow-hidden"
      >
        <div class="flex items-start justify-between">
          <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center">
            <Clock size={24} strokeWidth={2} class="text-orange-500" />
          </div>
          <span class="text-xs font-mono uppercase tracking-wider text-slate-400">
            Wartezeit
          </span>
        </div>
        <div>
          <div
            class="text-5xl md:text-6xl font-extrabold text-slate-900 tracking-tight leading-none"
          >
            <span data-counter data-target="4.533" data-format="time">0:00</span>
          </div>
          <p class="mt-2 text-sm text-slate-500">Ø Minuten in Zürich</p>
          <p class="mt-3 text-xs font-semibold text-emerald-600 inline-flex items-center gap-1">
            <TrendingDown size={14} strokeWidth={2.5} />
            18% schneller als Stadtdurchschnitt
          </p>
        </div>
      </article>

      <!-- TILE 2: Rating -->
      <article
        data-tile="1"
        class="bento-tile group col-span-6 md:col-span-4 row-span-1 relative bg-white border border-slate-200 rounded-2xl p-6 md:p-7 flex flex-col justify-between shadow-sm overflow-hidden"
      >
        <div data-stars class="flex gap-1">
          {
            [0, 1, 2, 3, 4].map(() => (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="star"
              >
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
              </svg>
            ))
          }
        </div>
        <div>
          <div
            class="text-5xl font-extrabold text-slate-900 tracking-tight leading-none"
          >
            4.9<span class="text-2xl text-slate-400 font-bold">/5</span>
          </div>
          <p class="mt-2 text-sm text-slate-500">aus 1'247 Bewertungen</p>
        </div>
      </article>

      <!-- TILE 3: Anrufzeit -->
      <article
        data-tile="2"
        class="bento-tile group col-span-6 md:col-span-3 row-span-1 relative bg-white border border-slate-200 rounded-2xl p-6 md:p-7 flex flex-col justify-between shadow-sm overflow-hidden"
      >
        <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center">
          <Phone size={22} strokeWidth={2} class="text-orange-500" />
        </div>
        <div>
          <div
            class="text-5xl font-extrabold text-slate-900 tracking-tight leading-none"
          >
            <span data-counter data-target="8" data-format="number">0</span>
            <span class="text-2xl text-slate-400 font-bold ml-1">Sek</span>
          </div>
          <p class="mt-2 text-sm text-slate-500">bis zur Anrufannahme</p>
        </div>
      </article>

      <!-- TILE 4: E-Hybrid Donut -->
      <article
        data-tile="3"
        class="bento-tile group col-span-6 md:col-span-3 row-span-1 relative bg-white border border-slate-200 rounded-2xl p-6 md:p-7 flex flex-col items-center justify-center shadow-sm overflow-hidden"
      >
        <div data-donut class="relative w-24 h-24 mb-3">
          <svg viewBox="0 0 80 80" class="w-full h-full -rotate-90">
            <circle
              cx="40"
              cy="40"
              r="32"
              stroke="rgb(241 245 249)"
              stroke-width="8"
              fill="none"></circle>
            <circle
              class="donut-progress"
              data-target="73"
              cx="40"
              cy="40"
              r="32"
              stroke="rgb(245 158 11)"
              stroke-width="8"
              fill="none"
              stroke-linecap="round"
              stroke-dasharray="201.06"
              stroke-dashoffset="201.06"></circle>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-2xl font-extrabold text-slate-900">73%</span>
          </div>
        </div>
        <p class="text-sm text-slate-600 text-center font-medium">
          Hybrid- & E-Fahrzeuge
        </p>
        <p class="text-xs text-slate-400 mt-1">in unserer Flotte</p>
      </article>

      <!-- TILE 5: Live-Map Zürich -->
      <article
        data-tile="4"
        class="bento-tile group col-span-12 md:col-span-6 row-span-1 relative bg-gradient-to-br from-blue-50 to-slate-50 border border-slate-200 rounded-2xl p-6 md:p-7 overflow-hidden"
      >
        <div
          class="absolute top-5 left-5 z-10 inline-flex items-center gap-2 bg-white/90 backdrop-blur-sm rounded-full px-3 py-1.5 shadow-sm border border-slate-200"
        >
          <span class="relative flex w-2 h-2">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-75"
            ></span>
            <span
              class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"
            ></span>
          </span>
          <span
            class="text-xs font-mono font-semibold text-slate-700 uppercase tracking-wide"
          >
            Live · 12 Fahrzeuge
          </span>
        </div>

        <div class="absolute bottom-5 right-5 z-10 text-xs text-slate-500 font-medium">
          Zürich & Umgebung
        </div>

        <svg
          viewBox="0 0 500 280"
          class="absolute inset-0 w-full h-full"
          preserveAspectRatio="xMidYMid meet"
        >
          <path
            d="M 80 240 Q 250 200 450 230 L 460 280 L 70 280 Z"
            fill="rgb(186 230 253)"
            opacity="0.5"></path>

          <path
            d="M 110 90 Q 100 60 150 50 L 250 40 Q 340 35 380 70 Q 420 95 410 140 Q 400 185 350 210 L 200 215 Q 130 210 105 170 Q 95 130 110 90 Z"
            fill="rgb(241 245 249)"
            stroke="rgb(203 213 225)"
            stroke-width="1.5"></path>

          <line
            x1="150"
            y1="80"
            x2="380"
            y2="180"
            stroke="rgb(203 213 225)"
            stroke-width="1.5"
            stroke-dasharray="3 3"></line>
          <line
            x1="200"
            y1="40"
            x2="280"
            y2="220"
            stroke="rgb(203 213 225)"
            stroke-width="1.5"
            stroke-dasharray="3 3"></line>

          <g transform="translate(250, 130)">
            <circle r="14" fill="rgb(245 158 11)" opacity="0.2">
              <animate
                attributeName="r"
                values="6;14;6"
                dur="2s"
                repeatCount="indefinite"></animate>
              <animate
                attributeName="opacity"
                values="0.3;0;0.3"
                dur="2s"
                repeatCount="indefinite"></animate>
            </circle>
            <circle r="5" fill="rgb(245 158 11)"></circle>
          </g>

          <g transform="translate(180, 70)">
            <circle r="14" fill="rgb(245 158 11)" opacity="0.2">
              <animate
                attributeName="r"
                values="6;14;6"
                dur="2s"
                begin="0.3s"
                repeatCount="indefinite"></animate>
              <animate
                attributeName="opacity"
                values="0.3;0;0.3"
                dur="2s"
                begin="0.3s"
                repeatCount="indefinite"></animate>
            </circle>
            <circle r="5" fill="rgb(245 158 11)"></circle>
          </g>

          <g transform="translate(290, 115)">
            <circle r="14" fill="rgb(245 158 11)" opacity="0.2">
              <animate
                attributeName="r"
                values="6;14;6"
                dur="2s"
                begin="0.6s"
                repeatCount="indefinite"></animate>
              <animate
                attributeName="opacity"
                values="0.3;0;0.3"
                dur="2s"
                begin="0.6s"
                repeatCount="indefinite"></animate>
            </circle>
            <circle r="5" fill="rgb(245 158 11)"></circle>
          </g>

          <g transform="translate(200, 150)">
            <circle r="14" fill="rgb(245 158 11)" opacity="0.2">
              <animate
                attributeName="r"
                values="6;14;6"
                dur="2s"
                begin="0.9s"
                repeatCount="indefinite"></animate>
              <animate
                attributeName="opacity"
                values="0.3;0;0.3"
                dur="2s"
                begin="0.9s"
                repeatCount="indefinite"></animate>
            </circle>
            <circle r="5" fill="rgb(245 158 11)"></circle>
          </g>

          <g transform="translate(280, 80)">
            <circle r="14" fill="rgb(245 158 11)" opacity="0.2">
              <animate
                attributeName="r"
                values="6;14;6"
                dur="2s"
                begin="1.2s"
                repeatCount="indefinite"></animate>
              <animate
                attributeName="opacity"
                values="0.3;0;0.3"
                dur="2s"
                begin="1.2s"
                repeatCount="indefinite"></animate>
            </circle>
            <circle r="5" fill="rgb(245 158 11)"></circle>
          </g>

          <g transform="translate(240, 185)">
            <circle r="14" fill="rgb(245 158 11)" opacity="0.2">
              <animate
                attributeName="r"
                values="6;14;6"
                dur="2s"
                begin="1.5s"
                repeatCount="indefinite"></animate>
              <animate
                attributeName="opacity"
                values="0.3;0;0.3"
                dur="2s"
                begin="1.5s"
                repeatCount="indefinite"></animate>
            </circle>
            <circle r="5" fill="rgb(245 158 11)"></circle>
          </g>
        </svg>
      </article>

      <!-- TILE 6: Konzession -->
      <article
        data-tile="5"
        class="bento-tile group col-span-6 md:col-span-3 row-span-1 relative bg-gradient-to-br from-blue-700 to-blue-900 border border-blue-700 rounded-2xl p-6 md:p-7 flex flex-col justify-between shadow-sm overflow-hidden"
      >
        <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">
          <ShieldCheck size={24} strokeWidth={2} class="text-orange-300" />
        </div>
        <div>
          <h3 class="text-lg font-bold text-white">Konzessioniert</h3>
          <p class="text-sm text-blue-200 mt-1 leading-tight">
            Offiziell zugelassen durch die Stadt Zürich
          </p>
          <div class="mt-3 w-12 h-0.5 bg-orange-400/60"></div>
        </div>
      </article>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const trustSection = document.getElementById("trust");
    if (!trustSection) return;

    const tiles = trustSection.querySelectorAll("[data-tile]");
    const grid = trustSection.querySelector("#bento-grid");
    let activeIndex = 0;
    let interval = null;
    let isHovered = false;
    let isVisible = false;

    function setActive(index) {
      tiles.forEach(function (tile, i) {
        if (i === index) tile.classList.add("tile-active");
        else tile.classList.remove("tile-active");
      });
    }

    function startRotation() {
      if (interval) return;
      interval = setInterval(function () {
        if (isHovered || !isVisible) return;
        activeIndex = (activeIndex + 1) % tiles.length;
        setActive(activeIndex);
      }, 4000);
    }

    setActive(0);

    grid &&
      grid.addEventListener("mouseenter", function () {
        isHovered = true;
      });
    grid &&
      grid.addEventListener("mouseleave", function () {
        isHovered = false;
      });

    const sectionObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          isVisible = entry.isIntersecting;
          if (isVisible) startRotation();
        });
      },
      { threshold: 0.3 }
    );
    sectionObserver.observe(trustSection);

    function animateCounter(el, target, duration, format) {
      duration = duration || 1500;
      format = format || "number";
      const startTime = performance.now();
      function update(now) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = target * eased;

        if (format === "time") {
          const totalSec = Math.floor(value * 60);
          const m = Math.floor(totalSec / 60);
          const s = totalSec % 60;
          el.textContent = m + ":" + String(s).padStart(2, "0");
        } else {
          el.textContent = String(Math.floor(value));
        }
        if (progress < 1) requestAnimationFrame(update);
      }
      requestAnimationFrame(update);
    }

    const counterObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            const el = entry.target;
            const target = parseFloat(el.dataset.target || "0");
            const format = el.dataset.format || "number";
            animateCounter(el, target, 1500, format);
            counterObserver.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );

    trustSection.querySelectorAll("[data-counter]").forEach(function (el) {
      counterObserver.observe(el);
    });

    const donutObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            const circle = entry.target.querySelector(".donut-progress");
            if (circle) {
              const target = parseFloat(circle.dataset.target || "0");
              const circ = 2 * Math.PI * 32;
              circle.style.strokeDashoffset = String(circ - (target / 100) * circ);
            }
            donutObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );

    trustSection.querySelectorAll("[data-donut]").forEach(function (el) {
      donutObserver.observe(el);
    });

    const starsObserver = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            const stars = entry.target.querySelectorAll(".star");
            stars.forEach(function (star, i) {
              setTimeout(function () {
                star.classList.add("star-filled");
                if (i === 4) {
                  star.style.fill = "url(#partial-fill)";
                  star.style.stroke = "rgb(245 158 11)";
                }
              }, i * 120);
            });
            starsObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.5 }
    );

    trustSection.querySelectorAll("[data-stars]").forEach(function (el) {
      starsObserver.observe(el);
    });
  })();
</script>

<style is:global>
  #trust .bento-tile {
    transition: all 700ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  #trust .tile-active {
    box-shadow: 0 20px 60px -15px rgba(245, 158, 11, 0.35);
    border-color: rgb(254 215 170) !important;
    transform: translateY(-2px) scale(1.005);
    z-index: 10;
  }
  #trust .star {
    transition: fill 300ms ease, stroke 300ms ease;
    fill: transparent;
    stroke: rgb(203 213 225);
  }
  #trust .star.star-filled {
    fill: rgb(245 158 11);
    stroke: rgb(245 158 11);
  }
  #trust .donut-progress {
    transition: stroke-dashoffset 1500ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    #trust .tile-active {
      transform: none;
    }
    #trust .bento-tile {
      transition: none;
    }
    #trust .donut-progress {
      transition: none;
    }
  }
</style>

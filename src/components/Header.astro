---
import { Phone } from "@lucide/astro";

const links = [
  { href: "/#services", label: "Services" },
  { href: "/#versprechen", label: "Versprechen" },
  { href: "/#kontakt", label: "Kontakt" },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-white border-b border-slate-200 shadow-sm"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-20">
      <a
        href="/"
        class="inline-flex items-center"
        aria-label="Taxi Shiar - Startseite"
      >
        <img
          src="/images/Taxi-shiar-logo.png"
          alt="Taxi Shiar Logo"
          class="h-14 md:h-16 w-auto object-contain"
          loading="eager"
          fetchpriority="high"
          width="711"
          height="400"
        />
      </a>

      <nav class="hidden md:flex items-center gap-10">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="header-link text-slate-700 hover:text-primary text-sm font-medium transition-colors duration-200"
            >
              {l.label}
            </a>
          ))
        }
      </nav>

      <div class="flex items-center gap-3">
        <a
          href="tel:+41796466087"
          class="hidden sm:inline-flex items-center gap-2 bg-accent text-primary font-semibold text-sm px-5 py-2.5 rounded-xl shadow-sm transition duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-accent/30"
        >
          <Phone size={18} strokeWidth={2.5} />
          <span class="hidden lg:inline">079 646 60 87</span>
        </a>
        <a
          href="tel:+41796466087"
          aria-label="Anrufen"
          class="sm:hidden inline-flex items-center justify-center w-11 h-11 bg-accent text-primary rounded-xl shadow-sm transition duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-accent/30"
        >
          <Phone size={20} strokeWidth={2.5} />
        </a>
        <button
          id="menu-toggle"
          aria-label="Menü öffnen"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden inline-flex flex-col items-center justify-center gap-1.5 w-11 h-11 rounded-xl"
        >
          <span class="block w-5 h-0.5 bg-slate-700"></span>
          <span class="block w-5 h-0.5 bg-slate-700"></span>
          <span class="block w-5 h-0.5 bg-slate-700"></span>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="mobile-menu md:hidden">
      <nav class="flex flex-col gap-1 pb-5">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="block px-2 py-3 text-slate-900 hover:text-primary text-base font-medium transition-colors"
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    const menuToggle = document.getElementById("menu-toggle");
    const mobileMenu = document.getElementById("mobile-menu");
    if (!menuToggle || !mobileMenu) return;

    menuToggle.addEventListener("click", function () {
      const open = mobileMenu.classList.toggle("open");
      menuToggle.setAttribute("aria-expanded", open ? "true" : "false");
    });
    mobileMenu.querySelectorAll("a").forEach(function (a) {
      a.addEventListener("click", function () {
        mobileMenu.classList.remove("open");
        menuToggle.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>

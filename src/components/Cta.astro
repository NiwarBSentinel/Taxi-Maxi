---
import { Phone } from "@lucide/astro";
---

<section class="py-20 sm:py-24 bg-gradient-to-br from-amber-50 via-amber-100 to-amber-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2
      class="text-dark font-extrabold tracking-tight text-3xl sm:text-4xl md:text-5xl leading-[1.15]"
    >
      Brauchen Sie jetzt ein Taxi?
    </h2>
    <p class="mt-5 text-lg text-dark/70 max-w-2xl mx-auto">
      Rufen Sie uns an — wir sind für Sie da, rund um die Uhr.
    </p>
    <div class="mt-10">
      <a
        href="tel:+41441234567"
        class="inline-flex items-center gap-3 bg-primary text-white text-xl sm:text-2xl font-bold px-8 py-5 rounded-xl shadow-lg transition duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-orange-500/30"
      >
        <Phone size={22} strokeWidth={2.5} class="text-white" />
        <span>044 123 45 67</span>
      </a>
      <p class="mt-5 text-sm text-slate-600">
        Lieber online buchen?
        <a href="#kontakt" class="underline hover:text-primary"
          >Hier zum Formular ↓</a
        >
      </p>
    </div>
  </div>
</section>

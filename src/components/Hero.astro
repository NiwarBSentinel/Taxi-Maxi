---
import { Phone, CheckCircle2 } from "@lucide/astro";

const phrases = [
  "zur Arbeit.",
  "zum Flughafen.",
  "zum Meeting.",
  "ins Restaurant.",
  "nach Hause.",
  "zum Bahnhof.",
];
---

<section
  class="relative min-h-[90vh] overflow-hidden bg-gradient-to-br from-primary via-primary to-dark flex items-center"
>
  <div class="absolute inset-0 bg-noise opacity-[0.07] pointer-events-none mix-blend-overlay"></div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(60% 50% at 25% 20%, rgba(59,130,246,0.35), transparent 65%);"
  >
  </div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(40% 40% at 90% 90%, rgba(245,158,11,0.18), transparent 65%);"
  >
  </div>

  <div
    class="hidden md:flex absolute top-28 right-6 lg:right-16 z-10 -rotate-6 bg-accent text-dark text-xs font-bold px-5 py-3 rounded-2xl shadow-lg items-center gap-2"
  >
    <CheckCircle2 size={14} strokeWidth={2.5} class="text-orange-700" />
    <span>Fixpreis möglich</span>
    <span class="opacity-50">·</span>
    <span>24/7 verfügbar</span>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-24 sm:pt-40 sm:pb-32 w-full">
    <p class="text-accent uppercase tracking-[0.25em] text-xs sm:text-sm font-semibold mb-6">
      Taxi-Service · Zürich
    </p>
    <h1
      class="text-white font-extrabold leading-[1.05] text-4xl sm:text-5xl md:text-6xl lg:text-7xl tracking-tight max-w-5xl"
    >
      Wir bringen Sie bequem und sicher{" "}
      <span class="block sm:inline-block min-w-[10ch]">
        <span id="rotating-word" class="rotating-word text-accent">zur Arbeit.</span>
      </span>
    </h1>
    <p class="mt-8 text-lg sm:text-xl text-white/80 max-w-2xl leading-relaxed">
      Ihr persönlicher Taxi-Service für Zürich und Umgebung. 24/7 verfügbar, fair tarifiert,
      immer pünktlich.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-4">
      <a
        href="tel:+41441234567"
        class="inline-flex items-center justify-center gap-2 bg-accent text-white font-bold text-base px-8 py-4 rounded-xl shadow-lg transition duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-orange-500/30"
      >
        <Phone size={20} strokeWidth={2.5} />
        Jetzt anrufen
      </a>
      <a
        href="#services"
        class="inline-flex items-center justify-center gap-2 border-2 border-white/40 hover:border-white text-white font-semibold text-base px-8 py-4 rounded-xl transition hover:bg-white/5"
      >
        Services entdecken
      </a>
    </div>
  </div>

  <script define:vars={{ phrases }}>
    const el = document.getElementById("rotating-word");
    if (el) {
      let i = 0;
      setInterval(() => {
        el.style.opacity = "0";
        setTimeout(() => {
          i = (i + 1) % phrases.length;
          el.textContent = phrases[i];
          el.style.opacity = "1";
        }, 300);
      }, 2500);
    }
  </script>
</section>

---
import {
  Leaf,
  VolumeX,
  Sparkles,
  TreeDeciduous,
  Zap,
} from "@lucide/astro";
---

<section id="flotte" class="relative py-24 md:py-32 bg-white overflow-hidden">
  <div
    class="absolute inset-0 bg-gradient-to-br from-emerald-50/30 via-white to-white pointer-events-none"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- LINKS: Text -->
      <div class="order-2 lg:order-1">
        <p
          class="inline-flex items-center gap-2 text-emerald-600 text-sm font-semibold uppercase tracking-widest mb-4"
        >
          <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
          Nachhaltigkeit
        </p>
        <h2
          class="text-slate-900 text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-6"
        >
          Komfort, der Sie <span class="text-primary">weiterbringt.</span>
        </h2>
        <p
          class="text-slate-600 text-lg md:text-xl leading-relaxed mb-8 max-w-xl"
        >
          Unsere Flotte besteht zu 73% aus Hybrid- und Elektrofahrzeugen.
          Modernste Modelle, leise im Betrieb, sparsam im Verbrauch — und so
          komfortabel, dass jede Fahrt ein Stück Erholung wird.
        </p>

        <ul class="space-y-4 mb-10">
          <li class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0 mt-0.5"
            >
              <Leaf size={20} strokeWidth={2} class="text-emerald-600" />
            </div>
            <div>
              <h3 class="font-bold text-slate-900 text-base mb-0.5">
                CO₂-arm unterwegs
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                Bis zu 60% weniger Emissionen pro Fahrt im Vergleich zu
                klassischen Verbrennern — gut für Sie, gut für Zürich.
              </p>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0 mt-0.5"
            >
              <VolumeX size={20} strokeWidth={2} class="text-emerald-600" />
            </div>
            <div>
              <h3 class="font-bold text-slate-900 text-base mb-0.5">
                Leise & entspannt
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                Hybrid-Antrieb läuft im Stadtverkehr nahezu lautlos. Telefonate,
                Musik, Gespräche — ohne Motorenlärm im Hintergrund.
              </p>
            </div>
          </li>

          <li class="flex items-start gap-4">
            <div
              class="w-10 h-10 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0 mt-0.5"
            >
              <Sparkles size={20} strokeWidth={2} class="text-emerald-600" />
            </div>
            <div>
              <h3 class="font-bold text-slate-900 text-base mb-0.5">
                Premium-Komfort serienmässig
              </h3>
              <p class="text-slate-600 text-sm leading-relaxed">
                Klimatisiert, geräumig, gepflegt. Wir reinigen unsere Fahrzeuge
                nach jeder Schicht — damit Sie sich wie ein Gast fühlen, nicht
                wie ein Passagier.
              </p>
            </div>
          </li>
        </ul>

        <div
          class="inline-flex items-center gap-3 bg-emerald-50 border border-emerald-200 rounded-2xl px-5 py-3.5"
        >
          <div
            class="w-10 h-10 rounded-full bg-emerald-500 flex items-center justify-center flex-shrink-0"
          >
            <TreeDeciduous size={20} strokeWidth={2} class="text-white" />
          </div>
          <div>
            <p class="text-sm font-bold text-emerald-900 leading-tight">
              <span data-eco-counter data-target="2400">0</span> kg CO₂
            </p>
            <p class="text-xs text-emerald-700 leading-tight">
              eingespart 2026 · gegenüber Verbrennerflotte
            </p>
          </div>
        </div>
      </div>

      <!-- RECHTS: Bild -->
      <div class="order-1 lg:order-2 relative">
        <div
          class="relative rounded-3xl overflow-hidden shadow-2xl shadow-slate-900/10 bg-gradient-to-br from-slate-50 to-slate-100 aspect-[4/3] lg:aspect-auto lg:h-[560px]"
        >
          <img
            src="/images/byd-fleet.webp"
            alt="BYD Hybrid-Fahrzeug der Taxi-Maxi-Flotte"
            loading="lazy"
            decoding="async"
            width="3200"
            height="1800"
            class="w-full h-full object-cover"
          />
          <div
            class="absolute inset-0 bg-gradient-to-tr from-slate-900/10 via-transparent to-transparent pointer-events-none"
          >
          </div>

          <div
            class="absolute bottom-6 left-6 bg-white rounded-2xl shadow-xl px-4 py-3 flex items-center gap-3 border border-slate-100"
          >
            <div
              class="w-10 h-10 rounded-full bg-emerald-100 flex items-center justify-center flex-shrink-0"
            >
              <Zap
                size={20}
                strokeWidth={2}
                fill="currentColor"
                class="text-emerald-600"
              />
            </div>
            <div>
              <p
                class="text-xs uppercase tracking-wider text-emerald-700 font-semibold leading-tight"
              >
                E-Hybrid
              </p>
              <p class="text-sm font-bold text-slate-900 leading-tight mt-0.5">
                73% der Flotte
              </p>
            </div>
          </div>
        </div>

        <div
          class="absolute -z-10 top-8 -right-8 w-32 h-32 rounded-full bg-gradient-to-br from-emerald-200/40 to-blue-200/40 blur-3xl"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const ecoSection = document.getElementById("flotte");
    if (!ecoSection) return;
    const counterEl = ecoSection.querySelector("[data-eco-counter]");
    if (!counterEl) return;

    const reduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    const target = parseInt(counterEl.dataset.target || "0", 10);

    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;

          if (reduced) {
            counterEl.textContent = target.toLocaleString("de-CH");
            observer.unobserve(counterEl);
            return;
          }

          const duration = 1800;
          const startTime = performance.now();

          function update(now) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            const value = Math.floor(target * eased);
            counterEl.textContent = value.toLocaleString("de-CH");
            if (progress < 1) requestAnimationFrame(update);
          }

          requestAnimationFrame(update);
          observer.unobserve(counterEl);
        });
      },
      { threshold: 0.5 }
    );
    observer.observe(counterEl);
  })();
</script>
